//@version=5
indicator("0DTE Sniper Buyer (Dynamic OTM)", overlay=true)

// ==========================
// 1. INPUTS & FILTERS
// ==========================
grpTime = "Time Filter (Exchange Time)"
startSession = input.int(11, "Start Hour", group=grpTime)
endSession   = input.int(13, "End Hour", group=grpTime)
endMin       = input.int(30, "End Minute", group=grpTime)

grpLogic = "Squeeze & Direction Logic"
bbLength = input.int(20, "BB Length", group=grpLogic)
bbMult   = input.float(2.0, "BB Multiplier", group=grpLogic)
atrMult  = input.float(2.0, "Strike ATR Multiplier", group=grpLogic, tooltip="Multiplier for Dynamic Strike Distance")

// Time Filter Logic
inSession = true
if time("D") // basic fallback
    hour_est = hour(time, "America/New_York")
    min_est  = minute(time, "America/New_York")
    timeFilter = (hour_est > startSession or (hour_est == startSession and min_est >= 0)) and (hour_est < endSession or (hour_est == endSession and min_est <= endMin))
    inSession := timeFilter

// ==========================
// 2. INDICATORS
// ==========================
// Bollinger Bands
[basis, upper, lower] = ta.bb(close, bbLength, bbMult)

// BB Width (Squeeze Detection)
bbrp = (close - lower) / (upper - lower)
bbWidth = (upper - lower) / basis
avgBBWidth = ta.sma(bbWidth, 50)
isSqueeze = bbWidth < avgBBWidth // Volatility is compressed

// MACD
[macdLine, signalLine, histLine] = ta.macd(close, 12, 26, 9)

// ATR for Dynamic Strike Distance
atr = ta.atr(14)
strikeDistance = atr * atrMult

// ==========================
// 3. TRIGGER LOGIC
// ==========================
bullishTrigger = inSession and close > upper and histLine > 0 and (histLine > histLine[1]) // Breakout UP + Momentum
bearishTrigger = inSession and close < lower and histLine < 0 and (histLine < histLine[1]) // Breakout DOWN + Momentum

// Limit signals to first candle of the breakout
var float lastBullTriggerTime = 0.0
var float lastBearTriggerTime = 0.0

isNewBull = bullishTrigger and not bullishTrigger[1]
isNewBear = bearishTrigger and not bearishTrigger[1]

// ==========================
// 4. PLOTS & VISUALS
// ==========================
plotshape(isNewBull, title="Buy Call", text="CALL", style=shape.labelup, location=location.belowbar, color=color.green, textcolor=color.white, size=size.small)
plotshape(isNewBear, title="Buy Put", text="PUT", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, size=size.small)

plot(basis, "BB Basis", color=color.gray)
p1 = plot(upper, "BB Upper", color=color.blue, transp=70)
p2 = plot(lower, "BB Lower", color=color.blue, transp=70)
fill(p1, p2, color=color.new(color.blue, 95))

// ==========================
// 5. DATA TABLE (HUD)
// ==========================
var table infoBox = table.new(position.top_right, 2, 5, border_width = 1, border_color = color.gray)

if barstate.islast
    table.cell(infoBox, 0, 0, "0DTE Sniper", bgcolor=color.new(color.blue, 80), text_color=color.white, width=10)
    table.cell(infoBox, 1, 0, inSession ? "ACTIVE" : "WAIT", bgcolor=inSession ? color.new(color.green,80) : color.new(color.yellow,80), text_color=color.white)
    
    table.cell(infoBox, 0, 1, "Status", bgcolor=color.new(color.black, 80), text_color=color.white)
    
    statusText = "SEARCHING"
    statusColor = color.new(color.gray, 50)
    recStrike = 0.0
    
    if isNewBull or (bullishTrigger and ta.barssince(isNewBull) < 5)
        statusText := "BUY CALL OTM"
        statusColor := color.new(color.green, 40)
        recStrike := close + strikeDistance
    else if isNewBear or (bearishTrigger and ta.barssince(isNewBear) < 5)
        statusText := "BUY PUT OTM"
        statusColor := color.new(color.red, 40)
        recStrike := close - strikeDistance
        
    table.cell(infoBox, 1, 1, statusText, bgcolor=statusColor, text_color=color.white)
    
    table.cell(infoBox, 0, 2, "Dynamic ATR", bgcolor=color.new(color.black, 80), text_color=color.white)
    table.cell(infoBox, 1, 2, str.tostring(math.round(atr, 2)) + " pts", bgcolor=color.new(color.black, 80), text_color=color.white)
    
    table.cell(infoBox, 0, 3, "Rec. Target Strike", bgcolor=color.new(color.black, 80), text_color=color.gray)
    table.cell(infoBox, 1, 3, recStrike == 0.0 ? "—" : str.tostring(math.round(recStrike, 0)), bgcolor=color.new(color.black, 80), text_color=color.yellow)
